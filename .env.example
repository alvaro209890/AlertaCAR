# AlertaCAR — variáveis de ambiente
PORT=3002
NODE_ENV=development

# Auth local — gere com: openssl rand -hex 64
JWT_SECRET=gerar_uma_secret_de_64_chars_hex

# Banco SQLite (PASTA DE SERVIDORES, não no repo)
DATABASE_PATH=/media/server/HD Backup/Servidores_NAO_MEXA/Banco_de_dados/AlertaCAR/alertacar.db

# SCCON
SCCON_ORG_UUID=597953b9-ee78-4113-80f9-803dbbaa60a0
SCCON_START_DATE=2019-07-22

# WFS SEMA-MT
WFS_BASE_URL=https://geo.sema.mt.gov.br/geoserver/ows
WFS_AUTHKEY=***n

# IA (DeepSeek, opcional). Nunca commitar a chave real.
DEEPSEEK_API_KEY=
DEEPSEEK_API_BASE_URL=https://api.deepseek.com/v1
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_TIMEOUT_MS=30000
DEEPSEEK_MAX_RETRIES=1
